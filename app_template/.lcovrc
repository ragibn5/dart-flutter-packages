# .lcovrc

# Inline exclusion markers
# (using lcov defaults, declared here for documentation)
lcov_excl_line    = LCOV_EXCL_LINE
lcov_excl_br_line = LCOV_EXCL_BR_LINE
lcov_excl_start   = LCOV_EXCL_START
lcov_excl_stop    = LCOV_EXCL_STOP

# DI setup
exclude = lib/di/config/**
exclude = lib/di/modules/**
exclude = lib/di/di.dart

# Generated directories and files
exclude = lib/generated/**
exclude = lib/**/*.g.dart
exclude = lib/**/*.gen.dart
exclude = lib/**/firebase_options_*.dart

# Entry points
exclude = lib/main_*.dart

# Models (data objects)
exclude = lib/**/models/**

# UI (widget tests not considered)
exclude = lib/**/presentation/widgets/**

# BLoC boilerplate
exclude = lib/**/*_event.dart
exclude = lib/**/*_state.dart

# Feature specifics
exclude = lib/features/app/infrastructure/config/**